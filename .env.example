# Supabase - https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Resend E-posta - https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Sporcu Paneli <noreply@resend.dev>

# NetGSM SMS (opsiyonel)
NETGSM_API_KEY=
NETGSM_SENDER_ID=

# PayTR (opsiyonel)
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Yeni özellikler (opsiyonel) ─────────────────────────────
# Web Push (Bildirim Gönder) — VAPID keys
# Oluştur: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@sporcupaneli.app

# Calendar Feed (iCal/Google Calendar) — HMAC imza
# Üret: openssl rand -hex 32
CALENDAR_HMAC_SECRET=

# AI Rapor (Anthropic Claude API)
ANTHROPIC_API_KEY=

# WhatsApp Business Cloud API (opsiyonel)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
